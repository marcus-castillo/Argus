# Copy to .env and adjust for local (non-Docker) development.
ENVIRONMENT=development
DEBUG=true

# Async DSN (asyncpg). Alembic derives the sync DSN automatically.
DATABASE_URL=postgresql+asyncpg://citecheck:citecheck@localhost:5432/citecheck

UPLOAD_DIR=./data/uploads
MAX_UPLOAD_BYTES=26214400

WORKER_POLL_INTERVAL_SECONDS=1.0
WORKER_BATCH_SIZE=5
JOB_MAX_ATTEMPTS=3

EMBEDDING_DIM=384
SEMANTIC_MATCH_THRESHOLD=0.82

CORS_ORIGINS=["http://localhost:3000"]
